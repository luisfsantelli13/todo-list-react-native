# Renomeie este arquivo para .env e preencha com seus dados reais do MongoDB Atlas

# String de conexão do MongoDB Atlas
# Pegue em: Atlas > Connect > Drivers > Node.js
# Troque <username>, <password> e <dbname> pelos seus dados
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority

# Porta onde a API vai rodar
PORT=3000
